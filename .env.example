# Application Configuration
# Port on which the server will run (default: 8080)
APP_PORT=8080

# Environment mode: development, staging, or production
# Controls security settings like cookie secure flag
APP_ENV=development

# Database Configuration
# PostgreSQL database host
DB_HOST=localhost

# PostgreSQL database port (default: 5432)
DB_PORT=5432

# PostgreSQL database username (required)
DB_USER=

# PostgreSQL database password (required)
DB_PASSWORD=

# PostgreSQL database name (required)
DB_NAME=blogcms

# JWT Configuration
# Secret key for JWT token signing (required)
# Use a strong, random string in production
JWT_SECRET=your-secret-key-change-this-in-production

# JWT token expiration duration (default: 24h)
# Valid units: ns, us, ms, s, m, h
# Examples: 30m, 2h, 24h, 168h
JWT_EXPIRES_IN=24h